{
  "name": "agentdev",
  "version": "0.5.0",
  "description": "Multi-Agent Collaborative Development Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agentdev": "./bin/agentdev.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "claude",
    "codex",
    "multi-agent",
    "development",
    "automation",
    "openclaw",
    "acp"
  ],
  "author": "dongdada",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dongdada29/agentdev"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
